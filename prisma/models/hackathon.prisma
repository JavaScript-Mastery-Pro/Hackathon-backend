model Hackathon {
  id          String   @id @default(cuid())
  name        String
  description String?
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  @@map("hackathon")
}
